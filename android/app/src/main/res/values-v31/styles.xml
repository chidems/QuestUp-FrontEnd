<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ draws its own system splash (centered app icon in a
         circle). It can't be skipped, but pointing its icon at a transparent
         drawable leaves just the flat brand-dark frame, which hands off
         seamlessly to the Flutter splash screen. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/launch_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
