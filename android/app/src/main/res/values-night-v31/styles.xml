<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night-mode copy of values-v31/styles.xml: the night qualifier outranks
         the version qualifier in resource matching, so without this a device
         in dark mode would fall back to values-night/styles.xml and show the
         system splash icon again. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/launch_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
